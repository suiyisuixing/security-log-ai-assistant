{
  "version": "1.0",
  "description": "Detection evaluation scenarios. Each scenario provides log content and expected rule IDs that should match.",
  "scenarios": [
    {
      "id": "detect_ssh_bruteforce",
      "name": "Detect SSH brute force",
      "source_type": "auth",
      "log_lines": [
        "2026-05-10T08:05:11Z sshd[1004]: Failed password for invalid user admin from 198.51.100.23 port 51445 ssh2",
        "2026-05-10T08:05:12Z sshd[1005]: Failed password for invalid user admin from 198.51.100.23 port 51446 ssh2",
        "2026-05-10T08:05:13Z sshd[1006]: Failed password for invalid user admin from 198.51.100.23 port 51447 ssh2",
        "2026-05-10T08:05:14Z sshd[1007]: Failed password for invalid user admin from 198.51.100.23 port 51448 ssh2",
        "2026-05-10T08:05:15Z sshd[1008]: Failed password for invalid user admin from 198.51.100.23 port 51449 ssh2",
        "2026-05-10T08:05:16Z sshd[1009]: Failed password for invalid user root from 198.51.100.23 port 51450 ssh2"
      ],
      "expected_rule_ids": ["R001", "R002"]
    },
    {
      "id": "detect_invalid_user_login",
      "name": "Detect invalid user login",
      "source_type": "auth",
      "log_lines": [
        "2026-05-10T08:05:11Z sshd[1004]: Failed password for invalid user admin from 198.51.100.23 port 51445 ssh2"
      ],
      "expected_rule_ids": ["R002"]
    },
    {
      "id": "detect_sudo_sensitive_file_access",
      "name": "Detect sudo sensitive file access",
      "source_type": "auth",
      "log_lines": [
        "2026-05-10T08:07:01Z sudo[2001]: alice : TTY=pts/0 ; PWD=/home/alice ; USER=root ; COMMAND=/usr/bin/cat /etc/shadow"
      ],
      "expected_rule_ids": ["R003", "R018"]
    },
    {
      "id": "detect_sql_injection",
      "name": "Detect SQL injection",
