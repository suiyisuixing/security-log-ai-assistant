      "log_lines": [
        "198.51.100.23 - - [10/May/2026:08:01:12 +0000] \"GET /products?id=1' OR '1'='1 HTTP/1.1\" 500 200 \"-\" \"sqlmap/1.6\""
      ],
      "expected_rule_ids": ["R004", "R008"]
    },
    {
      "id": "detect_xss_attempt",
      "name": "Detect XSS attempt",
